# Server Configuration
PORT=3002
NODE_ENV=production
API_KEY=mdmaim@#098

# Paths
DATA_PATH=./data
TEMP_PATH=./data/temp
CACHE_PATH=./data/cache
COOKIE_PATH=./data/cookies
LOG_PATH=./data/logs
BACKUP_PATH=./data/backups
DB_PATH=./data/database.sqlite

# Database
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL

# Cache Settings
CACHE_TTL_HOURS=24
MAX_CACHE_SIZE_MB=500
MAX_CACHE_FILES=1000
MEMORY_CACHE_TTL_MINUTES=5

# Cookie Settings
COOKIE_FAIL_THRESHOLD=5
MAX_COOKIE_AGE_DAYS=30
DELETE_COOKIE_FILES=false

# Download Settings
MAX_FILE_SIZE=1073741824  # 1GB
TEMP_RETENTION_HOURS=1
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
CONCURRENT_FRAGMENTS=4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Logging
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Backup
BACKUP_RETENTION_DAYS=7
STATS_RETENTION_DAYS=90

# Security
CORS_ORIGIN=*
ENABLE_API_KEYS=false
